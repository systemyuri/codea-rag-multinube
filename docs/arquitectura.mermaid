---
title: "Arquitectura Multi‑Cloud de CODEA RAG"
---

graph TB
    subgraph "👤 Usuario"
        U[Usuario Final]
        A[Administrador]
    end

    subgraph "☁️ Microsoft Azure"
        direction TB
        FE[Azure Static Web Apps<br/>Frontend React]
        ORCH[Azure Functions<br/>Orquestador RAG]
        LLM[Azure OpenAI<br/>GPT-4o + Embeddings]
        AI[Application Insights<br/>Observabilidad]
        
        FE --> ORCH
        ORCH --> LLM
        ORCH --> AI
    end

    subgraph "☁️ Amazon Web Services"
        direction TB
        S3[AWS S3<br/>Almacenamiento de PDFs]
        LAMBDA[AWS Lambda<br/>Ingesta Automática]
        
        A -->|Sube PDF| S3
        S3 -->|Evento| LAMBDA
    end

    subgraph "☁️ Google Cloud Platform"
        direction TB
        CHUNK[Cloud Run<br/>Chunking Service]
        RETRIEVAL[Cloud Run<br/>Retrieval Service]
        VDB[(AlloyDB + pgvector<br/>Base de Datos Vectorial)]
        LOGS[Cloud Logging & Monitoring<br/>Observabilidad]
        
        CHUNK --> VDB
        RETRIEVAL --> VDB
        RETRIEVAL --> LOGS
    end

    subgraph "🔀 Flujos de Datos"
        direction LR
        F1[Consulta del Usuario]
        F2[Ingesta de Documentos]
        F3[Respuesta Generada]
    end

    %% Conexiones del flujo de consulta
    U -->|Pregunta| FE
    FE -->|1. POST /ask| ORCH
    ORCH -->|2. Embedding| LLM
    LLM -->|Vector| ORCH
    ORCH -->|3. POST /retrieve<br/>(vector + filtros)| RETRIEVAL
    RETRIEVAL -->|4. Consulta SQL| VDB
    VDB -->|Chunks| RETRIEVAL
    RETRIEVAL -->|Chunks| ORCH
    ORCH -->|5. Prompt + Chunks| LLM
    LLM -->|6. Respuesta| ORCH
    ORCH -->|7. Respuesta| FE
    FE -->|8. Respuesta| U

    %% Conexiones del flujo de ingesta
    LAMBDA -->|POST /chunk<br/>(PDF + metadatos)| CHUNK
    CHUNK -->|Chunks + embeddings| VDB

    %% Seguridad
    subgraph "🔐 Seguridad"
        JWT[JWT Authentication]
        IAM[AWS IAM Roles]
        SA[GCP Service Accounts]
        PE[Azure Private Endpoints]
    end
    
    ORCH -.-> JWT
    LAMBDA -.-> IAM
    CHUNK -.-> SA
    RETRIEVAL -.-> SA
    FE -.-> JWT
    ORCH -.-> PE

    %% Observabilidad Cross-Cloud
    subgraph "📊 Observabilidad Cross-Cloud"
        AZURE_LOGS[Azure Log Analytics]
        AWS_LOGS[AWS CloudWatch]
        GCP_LOGS[GCP Cloud Logging]
    end
    
    ORCH --> AZURE_LOGS
    LAMBDA --> AWS_LOGS
    RETRIEVAL --> GCP_LOGS
    CHUNK --> GCP_LOGS
    VDB --> GCP_LOGS

    %% Estilos
    classDef azure fill:#0078D4,color:white,stroke:#005A9E
    classDef aws fill:#FF9900,color:white,stroke:#CC7A00
    classDef gcp fill:#4285F4,color:white,stroke:#2A56C6
    classDef user fill:#6C757D,color:white,stroke:#495057
    classDef security fill:#28A745,color:white,stroke:#1E7E34
    classDef observability fill:#17A2B8,color:white,stroke:#117A8B

    class FE,ORCH,LLM,AI,PE azure
    class S3,LAMBDA,IAM aws
    class CHUNK,RETRIEVAL,VDB,LOGS,SA gcp
    class U,A user
    class JWT,SA,IAM,PE security
    class AZURE_LOGS,AWS_LOGS,GCP_LOGS observability